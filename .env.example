# Copy this to .env and adjust the values for your machine.

# Required for watchdog mode.
JAY_WALLET=yjay1abc...xyz

# Mining threads/concurrency. Start conservative, then increase slowly.
JAY_THREADS=4

# Optional manual token fallback.
# If empty, the miner uses full-auto Camoufox token refresh by default.
JAY_MINING_TOKEN=

# Optional: force full-auto Camoufox token refresh even if JAY_MINING_TOKEN is set.
# Useful for private long-running mining where browser tokens expire.
JAY_AUTO_TOKEN=0

# Optional: send isJayWalletBrowser=true in the start_mining payload.
# Eligibility/rewards are decided by the official pool/server.
JAY_WALLET_BROWSER=0

# Optional watchdog settings.
JAY_RESTART_DELAY=15
JAY_MAX_RESTARTS=0
JAY_LOG_DIR=logs
JAY_EXTRA_ARGS=
